__pycache__/
*.egg-info/
dist/
build/
*.pyc

# Identity runtime state (runtime audit trail, per-environment).
# Any project that hosts identity workers via `claude-worker start --pm/--team-lead`
# ends up with this directory. Contents are logs of chats and actions
# the worker observed — environment-specific, potentially sensitive, and
# not something that should travel in git.
# .cwork/roles/ is the canonical name (see D62, D67).
# .claude-worker-pm/ and .cwork/pm/ are legacy names kept for compat.
.claude-worker-pm/
.cwork/pm/
.cwork/roles/
